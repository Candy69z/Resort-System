# ── Dependencies (re-installed inside the image) ──────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Next.js build output (rebuilt inside the image) ───────────
.next
out

# ── Environment & secrets — NEVER bake into the image ─────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ── Version control ───────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Editor / OS noise ─────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Documentation (not needed at runtime) ─────────────────────
*.md
LICENSE

# ── Docker files themselves (avoid COPY . . including them) ───
Dockerfile
docker-compose.yml
.dockerignore

# ── CI / testing ──────────────────────────────────────────────
.github
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
