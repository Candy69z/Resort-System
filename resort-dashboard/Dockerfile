# =============================================================
# Resort Dashboard — Production Dockerfile
# Multi-stage build:  deps → builder → runner
#
# Requires next.config.ts to have:  output: "standalone"
# This keeps the final image lean (~150 MB) by excluding
# node_modules from the runner stage entirely.
# =============================================================

# ── Stage 1: deps ─────────────────────────────────────────────
# Install ALL dependencies (including devDeps needed for build).
FROM node:20-alpine AS deps

# Install libc compatibility shims required by some native addons
# on Alpine (e.g. sharp, canvas). Safe to include even if unused.
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy manifests only — layer is cached unless deps change
COPY package.json package-lock.json* ./

# Use `npm ci` for reproducible, lock-file-exact installs.
# Falls back to `npm install` if no lockfile is present.
RUN \
  if [ -f package-lock.json ]; then npm ci; \
  else npm install; \
  fi


# ── Stage 2: builder ──────────────────────────────────────────
# Run the Next.js production build.
FROM node:20-alpine AS builder

WORKDIR /app

# Bring in installed modules from the deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy the full source (respects .dockerignore)
COPY . .

# Disable Next.js telemetry inside CI/CD environments
ENV NEXT_TELEMETRY_DISABLED=1

# Build the application.
# `output: "standalone"` in next.config.ts produces:
#   .next/standalone/  — self-contained Node server (no node_modules needed)
#   .next/static/      — pre-rendered assets
#   public/            — static public files
RUN npm run build


# ── Stage 3: runner ───────────────────────────────────────────
# Minimal production image — only the compiled artefacts.
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create a least-privilege system user; never run as root in prod
RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

# Copy only the artefacts required at runtime:
#   1. The standalone server bundle (includes its own mini node_modules)
#   2. Static assets served by Next.js
#   3. The public/ directory (favicon, images, etc.)
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static     ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public           ./public

USER nextjs

# Port the Next.js server listens on (must match docker-compose / cloud config)
EXPOSE 3000

# Bind to all interfaces inside the container so Docker port-mapping works
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# `server.js` is generated by the standalone build — no `npm` process needed
CMD ["node", "server.js"]
